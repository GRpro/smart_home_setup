# ──────────────────────────────────────────────
#  Copy this file to .env and fill in real values
#  NEVER commit .env to git
# ──────────────────────────────────────────────

# DuckDNS — https://www.duckdns.org (sign in → grab token from dashboard)
DUCKDNS_SUBDOMAIN=your-subdomain-here   # e.g. myhome  (without .duckdns.org)
DUCKDNS_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Let's Encrypt certificate email
LE_EMAIL=your@email.com

